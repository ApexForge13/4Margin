# ═══════════════════════════════════════════════════════════
# DecodeCoverage — Environment Variables
# Copy this file to .env.local and fill in your values.
# ═══════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────
# Project URL from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Service role key (server-side only, bypasses RLS)
# Supabase dashboard → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── AI (Anthropic) ───────────────────────────────────────
# API key for Claude policy parsing
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (Resend) ───────────────────────────────────────
# API key for transactional emails (email sequence + results delivery)
# https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Cron Security ────────────────────────────────────────
# Secret token for Vercel Cron job authentication
# Generate: openssl rand -base64 32
CRON_SECRET=your-random-secret-here

# ── Site URL ─────────────────────────────────────────────
# Base URL for email links and OG tags
# Use http://localhost:3001 for local dev
NEXT_PUBLIC_SITE_URL=https://decodecoverage.com

# ── Analytics (optional) ────────────────────────────────
# Google Analytics 4 Measurement ID
# https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta (Facebook) Pixel ID
# https://business.facebook.com → Events Manager → Pixels
NEXT_PUBLIC_META_PIXEL_ID=123456789012345

# Meta Conversions API (CAPI) — server-side event tracking
# System user access token from Business Manager → Settings → System Users
# https://business.facebook.com/settings/system-users
META_CAPI_ACCESS_TOKEN=your-system-user-token-here
